# Replace api.example.com with your real API domain.
# 192.168.0.194 is a temporary allowlist IP.
# For a VPS/server, replace it with the public IP of your friend's backend server.

api.example.com {
    @allowed remote_ip 192.168.0.194

    handle @allowed {
        reverse_proxy api:8000
    }

    handle {
        respond "Forbidden" 403
    }
}
